# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/swiftpay
# Docker: mongodb://admin:password@mongodb:27017/swiftpay?authSource=admin
MONGO_URI=mongodb://localhost:27017/swiftpay

# Required by docker-compose for the MongoDB container
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# Format: amqp://user:pass@host:port/vhost
RABBITMQ_URL=amqp://swiftpay:changeme@localhost:5672/swiftpay_vhost
RABBITMQ_USER=swiftpay
RABBITMQ_PASS=changeme

# ─── Auth secrets ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a DIFFERENT secret for each — never share them
ACCESS_SECRET=replace_with_random_64_char_hex
REFRESH_SECRET=replace_with_random_64_char_hex
VERIFY_SECRET=replace_with_random_64_char_hex

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# For Gmail, use an App Password (not your real password)
# https://support.google.com/accounts/answer/185833
MAIL_USER=your@email.com
MAIL_PASS=your_app_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ─── Payout / Worker ─────────────────────────────────────────────────────────
LOCK_TTL_MS=30000          # How long a distributed lock is held (ms)
WORKER_CONCURRENCY=5       # How many messages the worker processes at once
MAX_RETRY_ATTEMPTS=3       # How many times to retry a failed message
RETRY_DELAY_MS=5000        # Delay between retries (ms)

# ─── AI Features (optional) ───────────────────────────────────────────────────
# Set ENABLE_AI_FEATURES=true and add your Groq API key to enable fraud scoring
# Get a free key at: https://console.groq.com
ENABLE_AI_FEATURES=false
GROQ_API_KEY=
FRAUD_RISK_THRESHOLD=70    # Transactions with a score >= this are blocked

# ─── External APIs (optional) ─────────────────────────────────────────────────
# IP geolocation — uses ipapi.co (1000 free requests/day)
ENABLE_IP_VALIDATION=false

# Currency exchange rates — uses exchangerate-api.com (1500 free requests/month)
ENABLE_CURRENCY_VALIDATION=false
EXCHANGE_RATE_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
