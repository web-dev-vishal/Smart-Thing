# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017/swiftpay
# Docker: mongodb://admin:password@mongodb:27017/swiftpay?authSource=admin
MONGO_URI=mongodb://localhost:27017/swiftpay

# Required by docker-compose for the MongoDB container
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
# Format: amqp://user:pass@host:port/vhost
RABBITMQ_URL=amqp://swiftpay:changeme@localhost:5672/swiftpay_vhost
RABBITMQ_USER=swiftpay
RABBITMQ_PASS=changeme

# ─── Auth secrets (PASETO v4.public — Ed25519 key pairs) ─────────────────────
# Generate ALL SIX values with: node scripts/generate-keys.js
# Private keys SIGN tokens. Public keys VERIFY tokens.
# NEVER commit private keys to source control.
PASETO_ACCESS_PRIVATE=replace_with_128_char_hex_from_generate_keys
PASETO_ACCESS_PUBLIC=replace_with_64_char_hex_from_generate_keys

PASETO_REFRESH_PRIVATE=replace_with_128_char_hex_from_generate_keys
PASETO_REFRESH_PUBLIC=replace_with_64_char_hex_from_generate_keys

PASETO_VERIFY_PRIVATE=replace_with_128_char_hex_from_generate_keys
PASETO_VERIFY_PUBLIC=replace_with_64_char_hex_from_generate_keys

# Legacy JWT secrets — kept for backward compatibility during migration
# Remove these once all clients are using PASETO tokens
ACCESS_SECRET=replace_with_random_64_char_hex
REFRESH_SECRET=replace_with_random_64_char_hex
VERIFY_SECRET=replace_with_random_64_char_hex

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# For Gmail, use an App Password (not your real password)
# https://support.google.com/accounts/answer/185833
MAIL_USER=your@email.com
MAIL_PASS=your_app_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ─── Payout / Worker ─────────────────────────────────────────────────────────
LOCK_TTL_MS=30000          # How long a distributed lock is held (ms)
WORKER_CONCURRENCY=5       # How many messages the worker processes at once
MAX_RETRY_ATTEMPTS=3       # How many times to retry a failed message
RETRY_DELAY_MS=5000        # Delay between retries (ms)

# ─── AI Features ─────────────────────────────────────────────────────────────
# Groq — fast inference, Llama 3.3 70B. Free tier. https://console.groq.com
ENABLE_AI_FEATURES=false
GROQ_API_KEY=

# NVIDIA NIM — hosted inference API. Free Developer Program credits.
# Sign up: https://build.nvidia.com — get API key from profile
NVIDIA_API_KEY=

# OpenRouter — 25+ free models (DeepSeek, Gemma, Llama, Qwen).
# Free tier: 50 req/day. No credit card needed. https://openrouter.ai
OPENROUTER_API_KEY=

# App name shown in OpenRouter request headers (for attribution)
APP_NAME=NexusFlow

FRAUD_RISK_THRESHOLD=70    # Transactions with a score >= this are blocked

# ─── External APIs (optional) ─────────────────────────────────────────────────
# IP geolocation — uses ipapi.co (1000 free requests/day)
ENABLE_IP_VALIDATION=false

# Currency exchange rates — uses exchangerate-api.com (1500 free requests/month)
ENABLE_CURRENCY_VALIDATION=false
EXCHANGE_RATE_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error

# ─── Notifications (Email) ────────────────────────────────────────────────────
# Already configured above under "Email (Nodemailer)" — MAIL_USER and MAIL_PASS
# Set MAIL_SERVICE if not using Gmail (e.g. "hotmail", "yahoo", or leave blank for SMTP)
MAIL_SERVICE=gmail

# ─── Notifications (SMS via Twilio — optional) ────────────────────────────────
# Leave blank to disable SMS notifications
# Get credentials at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret header value required to access /api/admin/* endpoints
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=replace_with_random_secret

# ─── Scheduler ────────────────────────────────────────────────────────────────
# How often (in ms) the scheduler checks for due scheduled payouts
SCHEDULER_INTERVAL_MS=60000
