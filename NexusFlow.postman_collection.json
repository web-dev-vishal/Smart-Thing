{
  "info": {
    "_postman_id": "nexusflow-api-collection",
    "name": "NexusFlow API",
    "description": "Complete API collection for NexusFlow — AI-powered workflow automation and team collaboration platform built on Node.js, Express, MongoDB, Redis, RabbitMQ, Socket.IO, and PASETO auth.\n\n**Setup:**\n1. Set `baseUrl` variable to `http://localhost:5000`\n2. Register a user, then login to get `accessToken` and `refreshToken`\n3. Set those as collection variables\n4. All protected routes use `Bearer {{accessToken}}` automatically\n\n**Variable list:**\n- `baseUrl` — API base URL\n- `accessToken` — PASETO access token (15 min TTL)\n- `refreshToken` — PASETO refresh token (30 days)\n- `workspaceId` — active workspace ID\n- `channelId` — active channel ID\n- `messageId` — active message ID\n- `dmId` — active DM conversation ID\n- `workflowId` — active workflow ID\n- `executionId` — workflow execution ID\n- `userId` — payout user ID\n- `transactionId` — payout transaction ID\n- `webhookId` — active webhook ID",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken",   "value": "",                      "type": "string" },
    { "key": "refreshToken",  "value": "",                      "type": "string" },
    { "key": "workspaceId",   "value": "",                      "type": "string" },
    { "key": "channelId",     "value": "",                      "type": "string" },
    { "key": "messageId",     "value": "",                      "type": "string" },
    { "key": "dmId",          "value": "",                      "type": "string" },
    { "key": "workflowId",    "value": "",                      "type": "string" },
    { "key": "executionId",   "value": "",                      "type": "string" },
    { "key": "userId",        "value": "",                      "type": "string" },
    { "key": "transactionId", "value": "",                      "type": "string" },
    { "key": "webhookId",     "value": "",                      "type": "string" },
    { "key": "email",         "value": "test@example.com",      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "01 — Auth",
      "description": "User registration, login, token management. Run in order: Register → Verify Email → Login → use accessToken for everything else.",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Verify Email (Bearer = verification token from email)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer PASTE_VERIFY_TOKEN_FROM_EMAIL" }],
            "url": { "raw": "{{baseUrl}}/api/auth/verify-email", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-email"] }
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/resend-verification", "host": ["{{baseUrl}}"], "path": ["api","auth","resend-verification"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  const b = pm.response.json();",
              "  pm.collectionVariables.set('accessToken', b.accessToken);",
              "  pm.collectionVariables.set('refreshToken', b.refreshToken);",
              "  pm.test('Got tokens', () => pm.expect(b.accessToken).to.be.a('string'));",
              "}"
            ]}
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","auth","profile"] },
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"updateduser\"\n}" }
          }
        },
        {
          "name": "Refresh Access Token",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200) {",
              "  pm.collectionVariables.set('accessToken', pm.response.json().accessToken);",
              "}"
            ]}
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{refreshToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","auth","refresh-token"] }
          }
        },
        {
          "name": "Forgot Password (sends OTP)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","auth","forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/verify-otp/{{email}}", "host": ["{{baseUrl}}"], "path": ["api","auth","verify-otp","{{email}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"otp\": \"123456\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/change-password/{{email}}", "host": ["{{baseUrl}}"], "path": ["api","auth","change-password","{{email}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"newPassword\": \"NewPassword123!\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","auth","logout"] }
          }
        }
      ]
    },

    {
      "name": "02 — Workspaces",
      "description": "Create and manage workspaces. Create a workspace first — all channels, DMs, and workflows live inside one.",
      "item": [
        {
          "name": "Create Workspace",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('workspaceId', pm.response.json().workspace._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces", "host": ["{{baseUrl}}"], "path": ["api","workspaces"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Team\",\n  \"description\": \"Our main workspace\",\n  \"icon\": \"🚀\"\n}" }
          }
        },
        {
          "name": "List My Workspaces",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces", "host": ["{{baseUrl}}"], "path": ["api","workspaces"] }
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}"] }
          }
        },
        {
          "name": "Update Workspace",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Team Updated\",\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Invite Member",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/invite", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","invite"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"colleague@example.com\",\n  \"role\": \"member\"\n}" }
          }
        },
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","members"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Change Member Role",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/MEMBER_USER_ID/role", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","members","MEMBER_USER_ID","role"] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\"\n}" }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members/MEMBER_USER_ID", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","members","MEMBER_USER_ID"] }
          }
        },
        {
          "name": "Workspace Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/stats", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","stats"] }
          }
        },
        {
          "name": "Delete Workspace",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}"] }
          }
        }
      ]
    },

