    {
      "name": "07 — Webhooks",
      "description": "Incoming webhooks let external services trigger workflow events. Create a webhook → copy the secret → use webhookId for everything else.",
      "item": [
        {
          "name": "Create Webhook",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('webhookId', pm.response.json().webhook._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/webhooks", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","webhooks"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"GitHub CI\",\n  \"description\": \"Receives GitHub Actions events\",\n  \"workflowId\": \"{{workflowId}}\"\n}" }
