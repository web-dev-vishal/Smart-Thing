    {
      "name": "06 — Workflows",
      "description": "AI-powered workflow automation. Create a workflow → add trigger & actions → activate → execute. Use workflowId and executionId for subsequent requests.",
      "item": [
        {
          "name": "Create Workflow",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('workflowId', pm.response.json().workflow._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Member Onboarding\",\n  \"description\": \"Automatically welcome new workspace members\",\n  \"trigger\": {\n    \"type\": \"member_joined\",\n    \"config\": {}\n  },\n  \"actions\": [\n    {\n      \"type\": \"send_message\",\n      \"config\": {\n        \"channelId\": \"{{channelId}}\",\n        \"content\": \"Welcome to the team, {{user.username}}! 🎉\"\n      }\n    }\n  ]\n}" }
          }
        },
        {
          "name": "List Workflows",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Get Workflow",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}"] }
          }
        },
        {
          "name": "Update Workflow",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Member Onboarding (updated)\",\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Activate Workflow",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}/activate", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}","activate"] }
          }
        },
        {
          "name": "Deactivate Workflow",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}/deactivate", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}","deactivate"] }
          }
        },
        {
          "name": "Execute Workflow (manual trigger)",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 200 || pm.response.code === 202) {",
              "  pm.collectionVariables.set('executionId', pm.response.json().execution._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}/execute", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}","execute"] },
            "body": { "mode": "raw", "raw": "{\n  \"payload\": {}\n}" }
          }
        },
        {
          "name": "List Workflow Executions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}/executions?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}","executions"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Get Execution Details",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/workflows/{{workflowId}}/executions/{{executionId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","workflows","{{workflowId}}","executions","{{executionId}}"] }
          }
