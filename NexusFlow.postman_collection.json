    {
      "name": "05 — Direct Messages",
      "description": "One-on-one and group DM conversations. Create a conversation first — all DM messages live inside one. Run in order: Create Conversation → Send Message → use dmId for everything else.",
      "item": [
        {
          "name": "Create DM Conversation",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('dmId', pm.response.json().conversation._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/dm", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","dm"] },
            "body": { "mode": "raw", "raw": "{\n  \"participantIds\": [\"RECIPIENT_USER_ID\"]\n}" }
          }
        },
        {
          "name": "List DM Conversations",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/dm", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","dm"] }
          }
        },
        {
          "name": "Get DM Conversation",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/dm/{{dmId}}", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","dm","{{dmId}}"] }
          }
        },
        {
          "name": "Send DM Message",
          "event": [{
