              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/dm/{{dmId}}/messages", "host": ["{{baseUrl}}"], "path": ["api","workspaces","{{workspaceId}}","dm","{{dmId}}","messages"] },
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hey! 👋\"\n}" }
