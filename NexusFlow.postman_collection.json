    {
      "name": "08 — Payouts",
      "description": "Manage user payout accounts and transactions. Set userId before running payout requests. Run in order: Add Payout Account → Request Payout → track with transactionId.",
      "item": [
        {
          "name": "Get Payout Account",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/account", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","account"] }
          }
        },
        {
          "name": "Add Payout Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/account", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","account"] },
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"bank_transfer\",\n  \"details\": {\n    \"accountHolderName\": \"Test User\",\n    \"accountNumber\": \"0123456789\",\n    \"routingNumber\": \"110000000\",\n    \"currency\": \"USD\"\n  }\n}" }
          }
        },
        {
          "name": "Update Payout Account",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/account", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","account"] },
            "body": { "mode": "raw", "raw": "{\n  \"details\": {\n    \"accountHolderName\": \"Test User Updated\"\n  }\n}" }
          }
        },
        {
          "name": "Request Payout",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "if (pm.response.code === 201) {",
              "  pm.collectionVariables.set('transactionId', pm.response.json().transaction._id);",
              "}"
            ]}
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/request", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","request"] },
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 100.00,\n  \"currency\": \"USD\",\n  \"note\": \"Monthly payout\"\n}" }
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/transactions?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","transactions"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/transactions/{{transactionId}}", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","transactions","{{transactionId}}"] }
          }
        },
        {
          "name": "Cancel Transaction",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/transactions/{{transactionId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","transactions","{{transactionId}}","cancel"] }
          }
        },
        {
          "name": "Get Payout Balance",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/payouts/{{userId}}/balance", "host": ["{{baseUrl}}"], "path": ["api","payouts","{{userId}}","balance"] }
          }
        }
      ]
    }

