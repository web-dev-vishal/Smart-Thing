{
  "name": "swiftpay",
  "version": "1.0.0",
  "description": "SwiftPay Backend with AI-powered payout processing and fraud detection",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:gateway": "nodemon src/gateway/index.js",
    "dev:worker": "nodemon src/worker/index.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.cjs --coverage",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.cjs --watch",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.cjs tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.cjs tests/integration",
    "test:security": "NODE_OPTIONS=--experimental-vm-modules jest --config=jest.config.cjs tests/security",
    "test:performance": "artillery run tests/performance/load-test.yml",
    "test:coverage": "npm test && node scripts/check-coverage.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs",
    "docker:rebuild": "docker-compose up -d --build",
    "docker:test": "docker-compose -f docker-compose.test.yml up --abort-on-container-exit",
    "seed": "node scripts/seed.js",
    "setup:queue": "node scripts/create-queue.js"
  },
  "keywords": [
    "Node",
    "express",
    "payout",
    "rabbitmq",
    "redis",
    "mongodb",
    "websocket",
    "ai",
    "fraud-detection",
    "groq"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^0.10.9",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "joi": "^18.0.2",
    "mongoose": "^9.1.5",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "artillery": "^2.0.3",
    "eslint": "^9.39.2",
    "fast-check": "^3.15.0",
    "husky": "^8.0.3",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.2.0",
    "lint-staged": "^15.2.0",
    "mongodb-memory-server": "^9.1.5",
    "nodemon": "^3.1.11",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2"
  }
}