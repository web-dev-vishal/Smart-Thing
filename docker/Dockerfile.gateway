FROM node:20-alpine

WORKDIR /app

# wget is needed for the healthcheck in docker-compose
RUN apk add --no-cache wget

COPY package*.json ./
RUN npm install --omit=dev

COPY server.js ./
COPY src/ ./src/
COPY scripts/ ./scripts/

RUN mkdir -p /app/logs && chown -R node:node /app

EXPOSE 5000

USER node

CMD ["node", "server.js"]
